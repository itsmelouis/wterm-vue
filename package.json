{
  "name": "wterm-vue-monorepo",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm --filter @itsmelouis/wterm-vue build",
    "dev": "pnpm --filter playground-vue dev",
    "dev:nuxt": "pnpm --filter playground-nuxt dev",
    "type-check": "pnpm -r --parallel --if-present type-check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "playground:vue:build": "pnpm --filter playground-vue build",
    "playground:nuxt:build": "pnpm --filter playground-nuxt build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@changesets/cli": "^2.31.0",
    "eslint": "^10.2.1",
    "jiti": "^2.6.1"
  }
}
